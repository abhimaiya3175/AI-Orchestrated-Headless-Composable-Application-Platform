# LLM Configuration (Local - recommended)
LLM_PROVIDER=local
LLM_MODEL=llama2
OLLAMA_BASE_URL=http://localhost:11434

# Alternatively, if you plan to use OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_api_key_here

# External Services
OPENWEATHER_API_KEY=optional_weather_api_key

# Service URLs
ORCHESTRATOR_PORT=8000
FLIGHTS_SERVICE_URL=http://flights-service:8001
HOTELS_SERVICE_URL=http://hotels-service:8002
WEATHER_SERVICE_URL=http://weather-service:8003
PLACES_SERVICE_URL=http://places-service:8004
BUDGET_SERVICE_URL=http://budget-service:8005
LOG_LEVEL=INFO
